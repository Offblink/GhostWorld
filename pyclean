#!/usr/bin/env python
"""Recursively clear all __pycache__ dirs under a root directory.

Usage:
    pyclean                  # clean cwd
    pyclean /path/to/project # clean specific dir
    pyclean --dry-run        # show what would be deleted
"""
import os, shutil, sys, argparse

def pyclean(root: str, dry_run: bool = False) -> int:
    count = 0
    for dirpath, dirnames, _ in os.walk(root):
        if "__pycache__" in dirnames:
            p = os.path.join(dirpath, "__pycache__")
            if dry_run:
                n = sum(1 for _ in os.scandir(p))
                print(f"  would delete: {p} ({n} files)")
            else:
                shutil.rmtree(p)
                print(f"  deleted: {p}")
            count += 1
    return count

def main():
    p = argparse.ArgumentParser(description="Clear all __pycache__ directories")
    p.add_argument("root", nargs="?", default=".", help="root directory (default: .)")
    p.add_argument("--dry-run", "-n", action="store_true", help="show only, don't delete")
    args = p.parse_args()
    n = pyclean(os.path.abspath(args.root), args.dry_run)
    verb = "Would clear" if args.dry_run else "Cleared"
    print(f"{verb} {n} __pycache__ dir(s) in {args.root}")

if __name__ == "__main__":
    main()
